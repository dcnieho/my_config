          "template": " {{ if not .Writable }}<red>пЂЈ </>{{ end }}{{ .Path }} ",
          "foreground": "white",
          "type": "path",
          "style": "diamond"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "в•°в”Ђ",
          "foreground": "white",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<f>вљЎ</f>",
