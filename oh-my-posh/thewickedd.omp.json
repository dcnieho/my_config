{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "secondary_prompt": {
    "template": "в•°в”Ђ{{ if .Root }}<red><f>вљЎ</f></>{{ end }}оЉ…вќЇ ",
    "foreground": "white"
  },
  "transient_prompt": {
    "template": "<{{ if gt .Code 0 }}lightRed{{else}}lightGreen{{ end }},transparent>о‚¶</><darkGray,{{ if gt .Code 0 }}lightRed{{else}}lightGreen{{ end }}>{{ if gt .Code 0 }}пЂЌ{{ else }}пЂЊ{{ end }}{{ if (ne .Segments.Exit.Meaning (toString .Code)) }} {{ .Segments.Exit.Meaning }}{{ end }} </><lightWhite,darkGray> п‹І {{.Segments.Executiontime.FormattedMs}} </><darkGray,transparent>о‚ґ</>\nв•­в”Ђ(пЂ— {{ .Segments.Time.CurrentDate | date \"15:04:05\" }}) {{ if not .Segments.Path.Writable }}<red>пЂЈ </>{{ end }}{{ .Segments.Path.Location }}\nв•°в”Ђ{{ if .Root }}<red>вљЎ</>{{ end }}оЉ…вќЇ "
  },
  "console_title_template": "{{ if .Root }}(root) {{ end }}{{ .Shell }} @ {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "alpine": "пЊЂ",
            "arch": "пЊѓ",
            "cache_duration": "none",
            "centos": "пЊ„",
            "debian": "пЊ†",
            "elementary": "пЊ‰",
            "fedora": "пЊЉ",
            "gentoo": "пЊЌ",
            "linux": "оњ’",
            "macos": "оњ‘",
            "manjaro": "пЊ’",
            "mint": "пЊЏ",
            "opensuse": "пЊ”",
            "raspbian": "пЊ•",
            "ubuntu": "пЊњ",
            "windows": "оњЏ"
          },
          "leading_diamond": "о‚І",
          "template": " {{ .Icon }}{{ if .WSL }} on оњЏ {{ end }} ",
          "foreground": "lightWhite",
          "background": "darkGray",
          "type": "os",
