          "style": "powerline"
        },
        {
          "properties": {
            "branch_ahead_icon": "<green>в†‘</>",
            "branch_behind_icon": "<red>в†“</>",
            "branch_icon": "оњҐ",
            "cache_duration": "none",
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ url .RepoName .Kraken }} @ {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Staging.Changed }}<green> пЃ† {{ .Staging.String }}</>{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Working.Changed }}<red> пЃ„ {{ .Working.String }}</>{{ end }}{{ if gt .StashCount 0 }}<blue> (п†‡ {{ .StashCount }})</>{{ end }} ",
          "foreground": "black",
          "powerline_symbol": "о‚°",
          "background": "yellow",
          "type": "git",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "display_default": true,
            "display_mode": "context",
